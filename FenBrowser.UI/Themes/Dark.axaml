<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Modern Slate Palette - Dark -->
    <Color x:Key="BgColor">#0F172A</Color>      <!-- Slate-900 -->
    <Color x:Key="SurfaceColor">#1E293B</Color> <!-- Slate-800 -->
    <Color x:Key="BorderColor">#334155</Color>  <!-- Slate-700 -->
    <Color x:Key="PrimaryText">#F8FAFC</Color>  <!-- Slate-50 -->
    <Color x:Key="MutedText">#94A3B8</Color>    <!-- Slate-400 -->
    <Color x:Key="AccentColor">#60A5FA</Color>  <!-- Blue-400 (lighter for dark mode) -->
    <Color x:Key="HoverColor">#334155</Color>   <!-- Slate-700 -->
    <Color x:Key="PressedColor">#475569</Color> <!-- Slate-600 -->
    <Color x:Key="TabInactiveColor">#1E293B</Color> <!-- Slate-800 -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryText}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedText}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TabInactiveBrush" Color="{StaticResource TabInactiveColor}"/>
</ResourceDictionary>
