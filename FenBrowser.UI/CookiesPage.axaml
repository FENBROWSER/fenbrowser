<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="FenBrowser.UI.CookiesPage">
    <StackPanel Spacing="20">
        <TextBlock Text="Cookies and Site Data" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <StackPanel Spacing="10">
            <ToggleSwitch x:Name="BlockThirdPartyToggle" Content="Block third-party cookies" />
            <TextBlock Text="Prevents sites from using cookies that track you across the web." 
                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,-5,0,0"/>
        </StackPanel>

        <Button Content="Clear all browsing data" x:Name="ClearAllButton" Click="OnClearAllClick" 
                Background="{DynamicResource AccentBrush}" Foreground="White" Padding="15,8" CornerRadius="4"/>

        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="0">
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto" Margin="10">
                    <TextBlock Text="All cookies and site data" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Refresh" Click="OnRefreshClick" Classes="secondary"/>
                </Grid>
                <ListBox x:Name="CookiesList" Height="400" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Domain}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Value}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="🗑" Width="30" Height="30" 
                                        Click="OnDeleteCookieClick" Tag="{Binding}"
                                        Background="Transparent" BorderThickness="0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
