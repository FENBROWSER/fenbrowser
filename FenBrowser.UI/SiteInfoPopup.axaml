<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="400"
             x:Class="FenBrowser.UI.SiteInfoPopup"
             Width="320" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
        </Style>
        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.link:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2D2D2D"/>
        </Style>
        
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="16,16,12,12">
            <TextBlock x:Name="HeaderHost" Text="About example.com" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            <Button x:Name="CloseButton" Background="Transparent" Width="28" Height="28" Padding="4" CornerRadius="4" Click="OnCloseClick">
                <Path Data="M18 6L6 18M6 6l12 12" Stroke="#CCCCCC" StrokeThickness="1.5" Width="10" Height="10" Stretch="Uniform"/>
            </Button>
        </Grid>

        <Separator Background="#333333" Height="1" Margin="0"/>

        <!-- Connection Status -->
        <Button Classes="link">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Path Grid.Column="0" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" 
                      Fill="#FFFFFF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="Connection is secure" VerticalAlignment="Center"/>
                <Path Grid.Column="2" Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" Fill="#999999" Width="16" Height="16" Stretch="Uniform"/>
            </Grid>
        </Button>

        <Separator Background="#333333" Height="1" Margin="16,0"/>

        <!-- Permissions (Placeholder) -->
        <Button Classes="link">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Path Grid.Column="0" Data="M12 17c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6-9h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM8.9 6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2H8.9V6z" 
                      Fill="#FFFFFF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="Permissions for this site" VerticalAlignment="Center"/>
                <Path Grid.Column="2" Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" Fill="#999999" Width="16" Height="16" Stretch="Uniform"/>
            </Grid>
        </Button>

        <Separator Background="#333333" Height="1" Margin="0"/>

        <!-- Tracking Prevention -->
        <Grid Margin="0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="12,8">
                <Path Grid.Column="0" Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                      Fill="#FFFFFF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Tracking prevention" FontWeight="SemiBold"/>
                    <TextBlock Text="Balanced" FontSize="12" Foreground="#999999" Margin="0,2,0,0"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="2" x:Name="TrackingToggle" IsChecked="True" Checked="OnTrackingToggled" Unchecked="OnTrackingToggled"/>
            </Grid>

            <!-- Trackers Blocked Count -->
            <Button Grid.Row="1" Classes="link" Margin="0,0,0,4">
                <Grid ColumnDefinitions="28,*,Auto">
                    <TextBlock Grid.Column="1" Text="Trackers blocked" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock x:Name="BlockedCountText" Grid.Column="2" Text="0 blocked" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Path Grid.Column="3" Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" Fill="#999999" Width="16" Height="16" Stretch="Uniform"/>
                </Grid>
            </Button>
        </Grid>

    </StackPanel>
</UserControl>
