<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FenBrowser.UI"
        xmlns:rendering="using:FenBrowser.FenEngine.Rendering"
        x:Class="FenBrowser.UI.MainWindow"
        Title="FenBrowser"
        WindowState="Maximized"
        Width="1100" Height="700"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="42"
        TransparencyLevelHint="None"
        Background="{DynamicResource WindowBackgroundBrush}"
        x:Name="RootWindow">

	<!-- Theme brushes are now in App.axaml ThemeDictionaries -->
	<Window.Resources>
        <!-- No local overrides -->
	</Window.Resources>

	<Window.Styles>
		<!-- Icon button -->
		<Style Selector="Button.icon">
			<Setter Property="Width" Value="34"/>
			<Setter Property="Height" Value="34"/>
			<Setter Property="Padding" Value="6"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.icon:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverColor}"/>
		</Style>
		<Style Selector="Button.icon:pressed">
			<Setter Property="Background" Value="{DynamicResource PressedColor}"/>
		</Style>

		<Style Selector="Button.modern">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.modern:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverColor}"/>
		</Style>

		<!-- Modern Address Bar (Pill Shape) -->
		<Style Selector="TextBox#AddressBox">
			<Setter Property="MinWidth" Value="200"/>
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="Background" Value="{DynamicResource HoverColor}"/> <!-- Slightly darker/lighter than surface -->
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="2"/> 
			<Setter Property="CornerRadius" Value="18"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
			<Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
			<Setter Property="SelectionForegroundBrush" Value="White"/>
			<Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}"/>
		</Style>
		<Style Selector="TextBox#AddressBox:focus">
			<Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
			<!-- Add a subtle shadow simulation via border or elevation if possible, but keeping it flat for now -->
		</Style>
		<Style Selector="TextBox#AddressBox:pointerover">
			<Setter Property="Background" Value="{DynamicResource PressedColor}"/>
		</Style>

		<!-- Floating Tab Style (Edge-like) -->
		<Style Selector="ToggleButton.tab">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Margin" Value="4,4,4,0"/> <!-- Floating margin -->
			<Setter Property="Padding" Value="12,6,8,6"/>
			<Setter Property="CornerRadius" Value="8"/> <!-- Fully rounded top corners/floating card -->
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
					<DoubleTransition Property="Width" Duration="0:0:0.15" Easing="CircularEaseOut"/>
				</Transitions>
			</Setter>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Padding="{TemplateBinding Padding}">
						<ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		
		<!-- Inactive state (hover) -->
		<Style Selector="ToggleButton.tab:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverColor}"/>
		</Style>
		
		<!-- Active state - Connected to toolbar -->
		<Style Selector="ToggleButton.tab:checked">
			<Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/> <!-- Matches Toolbar background -->
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<!-- Remove bottom radius to connect to toolbar if we wanted strict connection, but floating card style often keeps simple rounded corners -->
            <Setter Property="CornerRadius" Value="8,8,0,0"/> 
            <Setter Property="Margin" Value="4,4,4,-1"/> <!-- Push down slightly to cover border line -->
		</Style>
		
		<!-- Tab close button style -->
		<Style Selector="Button.tab-close">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="4"/> 
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.tab-close:pointerover">
			<Setter Property="Background" Value="{DynamicResource PressedColor}"/> <!-- Stronger contrast for close -->
		</Style>
		<Style Selector="Button.tab-close:pressed">
			<Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Separator between tabs -->
		<Style Selector="ToggleButton.tab Border#Separator">
			<Setter Property="Background" Value="{DynamicResource BorderColor}"/>
			<Setter Property="Width" Value="1"/>
			<Setter Property="Height" Value="20"/>
			<Setter Property="Margin" Value="0,0,-5,0"/> <!-- Adjusted for spacing -->
			<Setter Property="HorizontalAlignment" Value="Right"/>
		</Style>
		<!-- Hide separator on active and hovered tabs -->
		<Style Selector="ToggleButton.tab:checked Border#Separator">
			<Setter Property="IsVisible" Value="False"/>
		</Style>
		<Style Selector="ToggleButton.tab:pointerover Border#Separator">
			<Setter Property="IsVisible" Value="False"/>
		</Style>

		<!-- ScrollBar Style -->
		<Style Selector="ScrollBar">
			<Setter Property="AllowAutoHide" Value="False"/>
		</Style>
		
		<Style Selector="ScrollBar:vertical">
			<Setter Property="Width" Value="6"/> <!-- Thinner scrollbar -->
		</Style>
		
		<Style Selector="ScrollBar:horizontal">
			<Setter Property="Height" Value="6"/>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb">
			<Setter Property="Background" Value="{DynamicResource PressedColor}"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb:pointerover">
			<Setter Property="Background" Value="{DynamicResource MutedTextBrush}"/>
		</Style>

	</Window.Styles>

	<Grid RowDefinitions="Auto,Auto,*" Margin="0">
		
		<!-- Custom Title Bar Area (Draggable) -->
        <!-- Increased height slightly to accommodate floating tabs -->
		<Grid Grid.Row="0" Height="48" Background="{DynamicResource SurfaceBrush}" ColumnDefinitions="Auto,*,Auto" PointerPressed="OnTitleBarPointerPressed">
			
			<!-- Left spacer / Icon (Draggable area) -->
			<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,12,0" Background="Transparent">
                <!-- App Title or Icon -->
                <TextBlock Text="FenBrowser" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
			</StackPanel>

			<!-- Tabs Container -->
			<ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,0">
				<StackPanel Orientation="Horizontal">
					<ItemsControl x:Name="TabsStrip">
						<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Panel>
								<ToggleButton Classes="tab"
											  IsChecked="{Binding IsActive, Mode=TwoWay}"
											  Click="OnTabClicked"
											  Width="{Binding #RootWindow.CurrentTabWidth}">
									<Grid ColumnDefinitions="Auto,Auto,*,Auto">
										<!-- Favicon -->
										<Path Grid.Column="0" Data="M12 2L2 7v10c0 5.52 3.82 10.65 9 12 5.18-1.35 9-6.48 9-12V7l-10-5z" 
											  Width="14" Height="14" Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" 
											  VerticalAlignment="Center" Margin="0,0,8,0"/>
										<TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12" 
												   Foreground="{Binding $parent[ToggleButton].Foreground}"
												   TextTrimming="CharacterEllipsis" 
												   HorizontalAlignment="Left"
												   VerticalAlignment="Center"
												   MaxWidth="120"/> 
										<!-- Spacer -->
										<Border Grid.Column="2"/>
                                        <!-- Vertical Separator (conditionally visible) -->
                                        <Border x:Name="Separator" Grid.Column="3" HorizontalAlignment="Right"/>
                                        
										<Button Grid.Column="3" Classes="tab-close" Width="20" Height="20" Click="OnCloseTab" Tag="{Binding Id}">
											<Path Data="M18 6L6 18M6 6l12 12" Stroke="{Binding $parent[ToggleButton].Foreground}" StrokeThickness="1.5" 
												  Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
										</Button>
									</Grid>
								</ToggleButton>
							</Panel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<Button Classes="modern" Click="OnNewTabClick" Margin="4,10,0,0" VerticalAlignment="Top" Height="28" Width="28" Padding="0">
					<Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
				</Button>
			</StackPanel>
		</ScrollViewer>

		<!-- Window Controls -->
		<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0">
			<Button Classes="icon" Click="OnMinimizeClick" ToolTip.Tip="Minimize" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Path Data="M6 11h12v2H6z" Width="10" Height="10" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
			<Button Classes="icon" Click="OnMaximizeClick" ToolTip.Tip="Maximize" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Path Data="M4 4h16v16H4V4zm2 4v10h12V8H6z" Width="10" Height="10" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
			<Button Classes="icon" Click="OnCloseClick" ToolTip.Tip="Close" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Button.Styles>
					<Style Selector="Button:pointerover /template/ ContentPresenter">
						<Setter Property="Background" Value="#E81123"/>
					</Style>
					<Style Selector="Button:pointerover Path">
						<Setter Property="Fill" Value="White"/>
					</Style>
				</Button.Styles>
				<Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
		</StackPanel>
		</Grid>

		<!-- Toolbar -->
        <!-- Toolbar blends with Active Tab via WindowBackgroundBrush -->
		<Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Padding="8,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
			<Grid VerticalAlignment="Center">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<!-- nav icons -->
					<ColumnDefinition Width="12"/>
					<ColumnDefinition Width="*"/>
					<!-- address -->
					<ColumnDefinition Width="Auto"/>
					<!-- extensions scroll -->
					<ColumnDefinition Width="Auto"/>
					<!-- overflow -->
					<ColumnDefinition Width="Auto"/>
					<!-- settings -->
					<ColumnDefinition Width="Auto"/>
					<!-- devtools -->
					<ColumnDefinition Width="Auto"/>
					<!-- menu -->
				</Grid.ColumnDefinitions>

				<!-- Navigation group -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
					<!-- Back -->
					<Button Classes="icon" Click="Back_Click" ToolTip.Tip="Back" Width="32" Height="32">
						<Path Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z"
							  Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
					</Button>

					<!-- Forward -->
					<Button Classes="icon" Click="Forward_Click" ToolTip.Tip="Forward" Width="32" Height="32">
						<Path Data="M12 4l-1.41 1.41 5.58 5.59H4v2h12.17l-5.58 5.59L12 20l8-8z"
							  Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
					</Button>

					<!-- Refresh -->
					<Button Classes="icon" Click="Refresh_Click" ToolTip.Tip="Refresh" Width="32" Height="32">
						<Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
							  Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
					</Button>
					
					<!-- Home -->
					<Button Classes="icon" Click="Home_Click" ToolTip.Tip="Home" Width="32" Height="32">
						<Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
							  Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
					</Button>
				</StackPanel>

				<!-- Address bar -->
				<Grid Grid.Column="2" VerticalAlignment="Center">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<TextBox x:Name="AddressBox" Grid.Column="0" Watermark="Search or enter web address" HorizontalAlignment="Stretch" KeyDown="AddressBox_KeyDown" Margin="4,0">
						<TextBox.InnerLeftContent>
                             <!-- Info Icon -->
							<Button x:Name="SiteInfoButton" Classes="icon" Width="26" Height="26" Margin="6,0,0,0" Click="OnSiteInfoClick" ToolTip.Tip="View site information" Background="Transparent">
								<Path x:Name="SecurityIconPath" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"
									  Width="12" Height="12" Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform"/>
							</Button>
						</TextBox.InnerLeftContent>
						<TextBox.InnerRightContent>
							<StackPanel Orientation="Horizontal">
                                <!-- Go Icon -->
								<Button Classes="icon" Width="26" Height="26" Margin="0,0,2,0" Click="OnGoClick" ToolTip.Tip="Go" Background="Transparent">
									<Path Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" Width="12" Height="12" Fill="{DynamicResource AccentBrush}" Stretch="Uniform"/>
								</Button>
								<!-- Bookmark Star -->
								<Button x:Name="BookmarkButton" Classes="icon" Width="26" Height="26" Margin="0,0,6,0" Click="OnBookmarkClick" ToolTip.Tip="Bookmark this page" Background="Transparent">
									<Path x:Name="BookmarkIconPath" Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" 
										  Width="14" Height="14" Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform"/>
								</Button>
							</StackPanel>
						</TextBox.InnerRightContent>
					</TextBox>
					
					<Popup x:Name="SiteInfoFlyout" PlacementTarget="{Binding ElementName=SiteInfoButton}" PlacementMode="Bottom" IsLightDismissEnabled="True" VerticalOffset="4">
						<local:SiteInfoPopup x:Name="SiteInfoContent"/>
					</Popup>
				</Grid>

				<!-- Extensions area -->
				<ScrollViewer Grid.Column="3" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="8,0" MaxWidth="200">
					<ItemsControl x:Name="ExtensionsArea">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="2"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Classes="icon" Width="32" Height="32" ToolTip.Tip="{Binding Name}" Click="OnExtensionClick">
									<TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="14"/>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

				<!-- Overflow (three dots) -->
				<Button Classes="icon" Grid.Column="4" Click="OnExtensionsOverflow" ToolTip.Tip="More extensions" Width="28">
					<Path Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
						  Width="4" Height="16" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
				</Button>

				<!-- DevTools -->
				<Button Classes="icon" Grid.Column="5" Click="OnDevToolsClick" ToolTip.Tip="Developer Tools" Margin="2,0,0,0" Width="36">
					<Path Data="M12.89 3L14.85 3.4L11.11 21L9.15 20.6L12.89 3M19.59 12L16 8.41V5.58L22.42 12L16 18.41V15.58L19.59 12M1.58 12L8 5.58V8.41L4.41 12L8 15.58V18.41L1.58 12Z"
						  Width="18" Height="18" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
				</Button>

				<!-- Settings cog -->
				<Button Classes="icon" Grid.Column="6" Click="OnSettingsClick" ToolTip.Tip="Settings" Margin="2,0,0,0" Width="36">
					<Path Data="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.06-.94l2.03-1.58a0.5 0.5 0 0 0 .12-.65l-1.92-3.32a0.5 0.5 0 0 0-.6-.22l-2.39.96a7.007 7.007 0 0 0-1.6-.94L14.5 2h-5l-.38 2.25c-.57.23-1.11.53-1.6.94L4.13 4.23a0.5 0.5 0 0 0-.6.22L1.61 7.77a0.5 0.5 0 0 0 .12.65L3.76 9.9c-.04.31-.06.63-.06.94s.02.63.06.94L1.61 13.36a0.5 0.5 0 0 0-.12.65l1.92 3.32c.14.24.43.34.68.22l2.39-.96c.49.41 1.03.71 1.6.94L9.5 22h5l.38-2.25c.57-.23 1.11-.53 1.6-.94l2.39.96c.25.1.54 0 .68-.22l1.92-3.32a0.5 0.5 0 0 0-.12-.65l-2.03-1.58zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"
						  Width="18" Height="18" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
				</Button>

				<!-- Menu Button (three dots) -->
				<Button Classes="icon" Grid.Column="7" Click="OnMenuClick" ToolTip.Tip="Menu" Margin="2,0,0,0" Width="36">
					<Path Data="M6 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm12 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
						  Width="18" Height="4" Fill="{DynamicResource PrimaryTextBrush}" Stretch="Uniform"/>
				</Button>
			</Grid>
		</Border>


		<!-- Loading Bar -->
		<ProgressBar x:Name="LoadingBar" Grid.Row="2" VerticalAlignment="Top" Height="2" IsIndeterminate="True" IsVisible="False" Background="Transparent" Foreground="{DynamicResource AccentBrush}" ZIndex="999"/>

		<!-- Content area -->
		<Border Grid.Row="2" Background="{DynamicResource WindowBackgroundBrush}">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto" MinHeight="0"/>
				</Grid.RowDefinitions>
				
				<Grid Grid.Row="0">
					<!-- Web content rendered by Skia -->
					<!-- Web content rendered by Skia -->
                    <Border Background="Transparent" ClipToBounds="True">
						<ScrollViewer x:Name="SkiaScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <local:SkiaBrowserView x:Name="SkiaView" IsHitTestVisible="True" />
                        </ScrollViewer>
                    </Border>
					
					<!-- Special pages container (Settings, etc.) -->
					<ContentControl x:Name="SpecialPageContainer" IsVisible="False" />
					
					<Canvas x:Name="HighlightOverlay" IsHitTestVisible="False"/>
				</Grid>
				
				<GridSplitter Grid.Row="1" Height="4" Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" HorizontalAlignment="Stretch" IsVisible="{Binding #DevToolsContainer.IsVisible}"/>
				
				<Border x:Name="DevToolsContainer" Grid.Row="2" Background="{DynamicResource WindowBackgroundBrush}" IsVisible="False">
					<!-- DevToolsView will be injected here -->
				</Border>
			</Grid>
		</Border>
	</Grid>
</Window>
