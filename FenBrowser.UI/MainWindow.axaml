<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FenBrowser.UI"
        x:Class="FenBrowser.UI.MainWindow"
        Title="FenBrowser"
        Width="1100" Height="700"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="42"
        TransparencyLevelHint="Mica, AcrylicBlur"
        Background="{DynamicResource WindowBackgroundBrush}"
        x:Name="RootWindow">

	<!-- Theme brushes -->
	<Window.Resources>
		<!-- Modern Slate Palette -->
		<Color x:Key="BgColor">#FFFFFF</Color>
		<Color x:Key="SurfaceColor">#F1F5F9</Color> <!-- Slate-100 -->
		<Color x:Key="BorderColor">#E2E8F0</Color>  <!-- Slate-200 -->
		<Color x:Key="PrimaryText">#0F172A</Color>  <!-- Slate-900 -->
		<Color x:Key="MutedText">#64748B</Color>    <!-- Slate-500 -->
		<Color x:Key="AccentColor">#3B82F6</Color>   <!-- Blue-500 -->
		<Color x:Key="HoverColor">#E2E8F0</Color>    <!-- Slate-200 -->
		<Color x:Key="PressedColor">#CBD5E1</Color>  <!-- Slate-300 -->
		<Color x:Key="TabInactiveColor">#E2E8F0</Color> <!-- Slate-200 -->

		<SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BgColor}"/>
		<SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
		<SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
		<SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryText}"/>
		<SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedText}"/>
		<SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
		<SolidColorBrush x:Key="TabInactiveBrush" Color="{StaticResource TabInactiveColor}"/>
	</Window.Resources>

	<Window.Styles>
		<!-- Icon button -->
		<Style Selector="Button.icon">
			<Setter Property="Width" Value="34"/>
			<Setter Property="Height" Value="34"/>
			<Setter Property="Padding" Value="6"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.icon:pointerover">
			<Setter Property="Background" Value="{StaticResource HoverColor}"/>
		</Style>
		<Style Selector="Button.icon:pressed">
			<Setter Property="Background" Value="{StaticResource PressedColor}"/>
		</Style>

		<Style Selector="Button.modern">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.modern:pointerover">
			<Setter Property="Background" Value="{StaticResource HoverColor}"/>
		</Style>

		<Style Selector="TextBox#AddressBox">
			<Setter Property="MinWidth" Value="200"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="Background" Value="#F1F5F9"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="18"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
			<Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
			<Setter Property="SelectionForegroundBrush" Value="White"/>
			<Setter Property="CaretBrush" Value="Black"/>
		</Style>
		<Style Selector="TextBox#AddressBox:focus">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>
		<Style Selector="TextBox#AddressBox:pointerover">
			<Setter Property="Background" Value="#E2E8F0"/>
		</Style>

		<!-- Tab Style -->
		<Style Selector="ToggleButton.tab">
			<Setter Property="Background" Value="#F3F3F3"/>
			<Setter Property="Margin" Value="0,6,0,0"/>
			<Setter Property="Padding" Value="10,6,8,6"/>
			<Setter Property="CornerRadius" Value="8,8,0,0"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
					<DoubleTransition Property="Width" Duration="0:0:0.15" Easing="CircularEaseOut"/>
				</Transitions>
			</Setter>
			<!-- Override default template to prevent green accent -->
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Padding="{TemplateBinding Padding}">
						<ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		
		<!-- Inactive state (hover) -->
		<Style Selector="ToggleButton.tab:pointerover">
			<Setter Property="Background" Value="#E8E8E8"/>
		</Style>
		
		<!-- Active state -->
		<Style Selector="ToggleButton.tab:checked">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		
		<!-- Tab close button style -->
		<Style Selector="Button.tab-close">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.tab-close:pointerover">
			<Setter Property="Background" Value="#E0E0E0"/>
		</Style>
		<Style Selector="Button.tab-close:pressed">
			<Setter Property="Background" Value="#D0D0D0"/>
		</Style>

		<!-- Separator between tabs -->
		<Style Selector="ToggleButton.tab Border#Separator">
			<Setter Property="Background" Value="{StaticResource BorderColor}"/>
			<Setter Property="Width" Value="1"/>
			<Setter Property="Height" Value="16"/>
			<Setter Property="Margin" Value="0,0,-1,0"/>
			<Setter Property="HorizontalAlignment" Value="Right"/>
		</Style>
		<Style Selector="ToggleButton.tab:checked Border#Separator">
			<Setter Property="IsVisible" Value="False"/>
		</Style>
		<Style Selector="ToggleButton.tab:pointerover Border#Separator">
			<Setter Property="IsVisible" Value="False"/>
		</Style>

		<!-- ScrollBar Style -->
		<Style Selector="ScrollBar">
			<Setter Property="AllowAutoHide" Value="False"/>
		</Style>
		
		<Style Selector="ScrollBar:vertical">
			<Setter Property="Width" Value="16"/>
		</Style>
		
		<Style Selector="ScrollBar:horizontal">
			<Setter Property="Height" Value="16"/>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb">
			<Setter Property="Background" Value="#C1C1C1"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb:pointerover">
			<Setter Property="Background" Value="#A8A8A8"/>
		</Style>

	</Window.Styles>

	<Grid RowDefinitions="Auto,Auto,*" Margin="0">
		
		<!-- Custom Title Bar Area (Draggable) -->
		<Grid Grid.Row="0" Height="42" Background="{StaticResource SurfaceColor}" ColumnDefinitions="Auto,*,Auto" PointerPressed="OnTitleBarPointerPressed">
			
			<!-- Left spacer / Icon (Draggable area) -->
			<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,8,0" Background="Transparent">
				<!-- App Icon placeholder -->
			</StackPanel>

			<!-- Tabs Container -->
			<ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,0">
				<StackPanel Orientation="Horizontal">
					<ItemsControl x:Name="TabsStrip">
						<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Panel>
								<ToggleButton Classes="tab"
											  IsChecked="{Binding IsActive, Mode=TwoWay}"
											  Click="OnTabClicked"
											  Width="{Binding #RootWindow.CurrentTabWidth}">
									<Grid ColumnDefinitions="Auto,Auto,*,Auto">
										<!-- Favicon placeholder -->
										<Path Grid.Column="0" Data="M12 2L2 7v10c0 5.52 3.82 10.65 9 12 5.18-1.35 9-6.48 9-12V7l-10-5z" 
											  Width="14" Height="14" Fill="#94A3B8" Stretch="Uniform" 
											  VerticalAlignment="Center" Margin="2,0,0,0"/>
										<TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" 
												   Foreground="{Binding $parent[ToggleButton].Foreground}"
												   TextTrimming="CharacterEllipsis" 
												   HorizontalAlignment="Left"
												   VerticalAlignment="Center"
												   MaxWidth="120" Margin="6,0,0,0"/> 
										<!-- Spacer to push close button right -->
										<Border Grid.Column="2"/>
										<Button Grid.Column="3" Classes="tab-close" Width="24" Height="24" Click="OnCloseTab" Tag="{Binding Id}">
											<Path Data="M18 6L6 18M6 6l12 12" Stroke="#605E5C" StrokeThickness="1.5" 
												  Width="12" Height="12" Stretch="Uniform"/>
										</Button>
									</Grid>
								</ToggleButton>
							</Panel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<Button Classes="modern" Click="OnNewTabClick" Margin="4,8,0,0" VerticalAlignment="Top" Height="28" Width="28" Padding="0">
					<Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Width="14" Height="14" Fill="#0F172A" Stretch="Uniform"/>
				</Button>
			</StackPanel>
		</ScrollViewer>

		<!-- Window Controls -->
		<!-- Window Controls -->
		<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0">
			<Button Classes="icon" Click="OnMinimizeClick" ToolTip.Tip="Minimize" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Path Data="M6 11h12v2H6z" Width="10" Height="10" Fill="#0F172A" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
			<Button Classes="icon" Click="OnMaximizeClick" ToolTip.Tip="Maximize" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Path Data="M4 4h16v16H4V4zm2 4v10h12V8H6z" Width="10" Height="10" Fill="#0F172A" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
			<Button Classes="icon" Click="OnCloseClick" ToolTip.Tip="Close" Width="46" Height="32" CornerRadius="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
				<Button.Styles>
					<Style Selector="Button:pointerover /template/ ContentPresenter">
						<Setter Property="Background" Value="#E81123"/>
					</Style>
					<Style Selector="Button:pointerover Path">
						<Setter Property="Fill" Value="White"/>
					</Style>
				</Button.Styles>
				<Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Fill="#0F172A" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Button>
		</StackPanel>
		</Grid>

		<!-- Toolbar -->
		<Border Grid.Row="1" Background="#FFFFFF" Padding="12,8" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
			<Grid VerticalAlignment="Center">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<!-- nav icons -->
					<ColumnDefinition Width="16"/>
					<ColumnDefinition Width="*"/>
					<!-- address -->
					<ColumnDefinition Width="Auto"/>
					<!-- extensions scroll -->
					<ColumnDefinition Width="Auto"/>
					<!-- overflow -->
					<ColumnDefinition Width="Auto"/>
					<!-- settings -->
					<ColumnDefinition Width="Auto"/>
					<!-- devtools -->
					<ColumnDefinition Width="Auto"/>
					<!-- menu -->
				</Grid.ColumnDefinitions>

				<!-- Navigation group -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<!-- Back -->
					<Button Classes="icon" Click="Back_Click" ToolTip.Tip="Back">
						<Path Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z"
							  Width="16" Height="16" Fill="#0F172A" Stretch="Uniform"/>
					</Button>

					<!-- Forward -->
					<Button Classes="icon" Click="Forward_Click" ToolTip.Tip="Forward">
						<Path Data="M12 4l1.41 1.41L7.83 11H20v2H7.83l5.58 5.59L12 20l-8-8 8-8z"
							  Width="16" Height="16" Fill="#0F172A" Stretch="Uniform"
							  >
							<Path.RenderTransform>
								<ScaleTransform ScaleX="-1"/>
							</Path.RenderTransform>
						</Path>
					</Button>

					<!-- Refresh -->
					<Button Classes="icon" Click="Refresh_Click" ToolTip.Tip="Refresh">
						<Path Data="M17.65 6.35A8 8 0 1 0 19.93 12h2.02A10 10 0 1 1 15 2v2l4-4l-4-4"
							  Width="16" Height="16" Fill="#0F172A" Stretch="Uniform"/>
					</Button>
				</StackPanel>

				<!-- Address bar -->
				<Grid Grid.Column="2" VerticalAlignment="Center">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<TextBox x:Name="AddressBox" Grid.Column="0" Watermark="Search or enter address" HorizontalAlignment="Stretch" KeyDown="AddressBox_KeyDown">
						<TextBox.InnerLeftContent>
							<Button x:Name="SiteInfoButton" Classes="icon" Width="28" Height="28" Margin="4,0,0,0" Click="OnSiteInfoClick" ToolTip.Tip="View site information">
								<Path x:Name="SecurityIconPath" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"
									  Width="14" Height="14" Fill="#64748B" Stretch="Uniform"/>
							</Button>
						</TextBox.InnerLeftContent>
						<TextBox.InnerRightContent>
							<StackPanel Orientation="Horizontal">
								<Button Classes="icon" Width="28" Height="28" Margin="0,0,4,0" Click="OnGoClick" ToolTip.Tip="Go">
									<Path Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" Width="14" Height="14" Fill="#3B82F6" Stretch="Uniform"/>
								</Button>
							</StackPanel>
						</TextBox.InnerRightContent>
					</TextBox>
					
					<Popup x:Name="SiteInfoFlyout" PlacementTarget="{Binding ElementName=SiteInfoButton}" PlacementMode="Bottom" IsLightDismissEnabled="True" VerticalOffset="4">
						<local:SiteInfoPopup x:Name="SiteInfoContent"/>
					</Popup>
				</Grid>

				<!-- Extensions area -->
				<ScrollViewer Grid.Column="3" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="16,0" MaxWidth="200">
					<ItemsControl x:Name="ExtensionsArea">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="4"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Classes="icon" Width="32" Height="32" ToolTip.Tip="{Binding Name}" Click="OnExtensionClick">
									<TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="14"/>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

				<!-- Overflow (three dots) -->
				<Button Classes="icon" Grid.Column="4" Click="OnExtensionsOverflow" ToolTip.Tip="More extensions">
					<Path Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
						  Width="4" Height="16" Fill="#0F172A" Stretch="Uniform"/>
				</Button>

				<!-- DevTools -->
				<Button Classes="icon" Grid.Column="5" Click="OnDevToolsClick" ToolTip.Tip="Developer Tools" Margin="4,0,0,0">
					<Path Data="M12.89 3L14.85 3.4L11.11 21L9.15 20.6L12.89 3M19.59 12L16 8.41V5.58L22.42 12L16 18.41V15.58L19.59 12M1.58 12L8 5.58V8.41L4.41 12L8 15.58V18.41L1.58 12Z"
						  Width="18" Height="18" Fill="#0F172A" Stretch="Uniform"/>
				</Button>

				<!-- Settings cog -->
				<Button Classes="icon" Grid.Column="6" Click="OnSettingsClick" ToolTip.Tip="Settings" Margin="4,0,0,0">
					<Path Data="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.06-.94l2.03-1.58a0.5 0.5 0 0 0 .12-.65l-1.92-3.32a0.5 0.5 0 0 0-.6-.22l-2.39.96a7.007 7.007 0 0 0-1.6-.94L14.5 2h-5l-.38 2.25c-.57.23-1.11.53-1.6.94L4.13 4.23a0.5 0.5 0 0 0-.6.22L1.61 7.77a0.5 0.5 0 0 0 .12.65L3.76 9.9c-.04.31-.06.63-.06.94s.02.63.06.94L1.61 13.36a0.5 0.5 0 0 0-.12.65l1.92 3.32c.14.24.43.34.68.22l2.39-.96c.49.41 1.03.71 1.6.94L9.5 22h5l.38-2.25c.57-.23 1.11-.53 1.6-.94l2.39.96c.25.1.54 0 .68-.22l1.92-3.32a0.5 0.5 0 0 0-.12-.65l-2.03-1.58zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"
						  Width="18" Height="18" Fill="#0F172A" Stretch="Uniform"/>
				</Button>

				<!-- Menu Button (three dots) -->
				<Button Classes="icon" Grid.Column="7" Click="OnMenuClick" ToolTip.Tip="Menu" Margin="4,0,0,0">
					<Path Data="M6 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm12 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
						  Width="18" Height="4" Fill="#0F172A" Stretch="Uniform"/>
				</Button>
			</Grid>
		</Border>


		<!-- Loading Bar -->
		<ProgressBar x:Name="LoadingBar" Grid.Row="2" VerticalAlignment="Top" Height="3" IsIndeterminate="True" IsVisible="False" Background="Transparent" Foreground="{StaticResource AccentBrush}" ZIndex="999"/>

		<!-- Content area -->
		<Border Grid.Row="2" Background="#FFFFFF">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto" MinHeight="0"/>
				</Grid.RowDefinitions>
				
				<Grid Grid.Row="0">
					<Border x:Name="BrowserContainer" Background="White">
						<TextBlock Text="Ready" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/>
					</Border>
					<Canvas x:Name="HighlightOverlay" IsHitTestVisible="False"/>
				</Grid>
				
				<GridSplitter Grid.Row="1" Height="4" Background="#E2E8F0" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>
				
				<Border x:Name="DevToolsContainer" Grid.Row="2" Background="#FFFFFF" Height="0" IsVisible="False">
					<!-- DevToolsView will be injected here -->
				</Border>
			</Grid>
		</Border>
	</Grid>
</Window>
