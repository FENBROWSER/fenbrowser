<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FenBrowser.UI.SettingsPage"
             xmlns:local="clr-namespace:FenBrowser.UI"
             x:Name="SettingsRoot">

	<UserControl.Resources>
		<!-- Local overrides removed to use global ThemeDictionaries -->
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Radio Button Style -->
		<Style Selector="RadioButton">
			<Setter Property="Margin" Value="0,8,0,0"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
		</Style>

		<!-- Primary Button -->
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
			<Setter Property="Foreground" Value="#FFFFFF"/> 
			<Setter Property="Padding" Value="16,8"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="MinWidth" Value="80"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<Style Selector="Button.primary:pointerover">
			<Setter Property="Background" Value="#106EBE"/> 
		</Style>

		<!-- Secondary Button -->
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="Padding" Value="16,8"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="MinWidth" Value="80"/>
		</Style>

		<Style Selector="Button.secondary:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverColor}"/>
		</Style>
	</UserControl.Styles>

	<Grid ColumnDefinitions="Auto,*" Background="{DynamicResource WindowBackgroundBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
		<!-- Left Navigation Panel -->
		<Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" MinWidth="150" MaxWidth="200">
			<StackPanel Margin="0,20,0,0">
				<TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="20,0,0,20" Foreground="{DynamicResource PrimaryTextBrush}"/>
				
				<!-- Navigation Items -->
				<Border x:Name="NavGeneral" Background="{DynamicResource HoverColor}" Padding="12,10" Margin="0,0,0,2" PointerPressed="OnNavGeneralClick">
					<TextBlock Text="General" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
				</Border>
				<Border x:Name="NavPrivacy" Background="Transparent" Padding="12,10" Margin="0,0,0,2" PointerPressed="OnNavPrivacyClick">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="🔒"/>
						<TextBlock Text="Privacy" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
					</StackPanel>
				</Border>
				<Border x:Name="NavDeveloper" Background="Transparent" Padding="12,10" Margin="0,0,0,2" PointerPressed="OnNavDeveloperClick">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="🛠️"/>
						<TextBlock Text="Developer" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>

		<!-- Right Content Panel -->
		<ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<Panel Margin="20,20,20,20" MaxWidth="600" HorizontalAlignment="Stretch">
				<!-- General Settings -->
				<StackPanel x:Name="GeneralPanel">

				<TextBlock Text="General Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,30" Foreground="{DynamicResource PrimaryTextBrush}"/>

				<!-- Appearance Section -->
				<Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
					<StackPanel>
						<TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
						<TextBlock Text="Choose your preferred theme." 
								   TextWrapping="Wrap" 
								   Margin="0,0,0,16"
								   Foreground="{DynamicResource MutedTextBrush}"/>

						<StackPanel x:Name="ThemePanel" Orientation="Horizontal" Spacing="20">
							<RadioButton x:Name="ThemeSystemRadio" Content="System Default" GroupName="Theme"/>
							<RadioButton x:Name="ThemeLightRadio" Content="Light" GroupName="Theme"/>
							<RadioButton x:Name="ThemeDarkRadio" Content="Dark" GroupName="Theme"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- User-Agent Section -->
				<Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
					<StackPanel>
						<TextBlock Text="Browser Identity (User-Agent)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
						<TextBlock Text="Choose how websites identify your browser. Chrome is recommended for best compatibility." 
								   TextWrapping="Wrap" 
								   Margin="0,0,0,16"
								   Foreground="{DynamicResource MutedTextBrush}"/>

						<StackPanel x:Name="UserAgentPanel">
							<RadioButton x:Name="ChromeRadio" Content="Chrome (Recommended)" GroupName="UserAgent"/>
							<TextBlock Text="Best compatibility with modern websites" 
									   Margin="28,0,0,0" 
									   FontSize="12" 
									   Foreground="{DynamicResource MutedTextBrush}"/>

							<RadioButton x:Name="FirefoxRadio" Content="Firefox" GroupName="UserAgent" Margin="0,12,0,0"/>
							<TextBlock Text="Alternative browser identity for privacy-focused sites" 
									   Margin="28,0,0,0" 
									   FontSize="12" 
									   Foreground="{DynamicResource MutedTextBrush}"/>

							<RadioButton x:Name="FenBrowserRadio" Content="FenBrowser" GroupName="UserAgent" Margin="0,12,0,0"/>
							<TextBlock Text="Custom FenBrowser identity - may not be recognized by all sites" 
									   Margin="28,0,0,0" 
									   FontSize="12" 
									   Foreground="{DynamicResource MutedTextBrush}"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- JavaScript Section -->
				<Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
					<StackPanel>
						<TextBlock Text="JavaScript" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
						<TextBlock Text="Control whether websites can run JavaScript. Disabling may break site functionality but improves security and privacy." 
								   TextWrapping="Wrap" 
								   Margin="0,0,0,16"
								   Foreground="{DynamicResource MutedTextBrush}"/>

						<ToggleSwitch x:Name="EnableJavaScriptSwitch" Content="Enable JavaScript" IsChecked="True"/>
						<TextBlock Text="Recommended: Keep enabled for best website compatibility" 
								   FontSize="12" 
								   Margin="0,4,0,0"
								   Foreground="{DynamicResource MutedTextBrush}"/>
					</StackPanel>
				</Border>

				<!-- Logging Section -->
				<Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
					<StackPanel>
						<TextBlock Text="Debug Logging" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
						<TextBlock Text="Enable detailed logging for debugging issues. Logs are saved to your AppData folder." 
								   TextWrapping="Wrap" 
								   Margin="0,0,0,16"
								   Foreground="{DynamicResource MutedTextBrush}"/>

						<ToggleSwitch x:Name="EnableLoggingSwitch" Content="Enable Logging" Margin="0,0,0,16"/>

						<TextBlock Text="Log Categories" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
						<TextBlock Text="Choose which components to log:" 
								   FontSize="12" 
								   Margin="0,0,0,8"
								   Foreground="{DynamicResource MutedTextBrush}"/>

						<StackPanel x:Name="LogCategoriesPanel" Spacing="4">
							<CheckBox x:Name="LogNavigationCheck" Content="Navigation" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogRenderingCheck" Content="Rendering" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogCSSCheck" Content="CSS" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogJavaScriptCheck" Content="JavaScript" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogNetworkCheck" Content="Network" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogImagesCheck" Content="Images" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogLayoutCheck" Content="Layout" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogEventsCheck" Content="Events" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogStorageCheck" Content="Storage" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogPerformanceCheck" Content="Performance" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<CheckBox x:Name="LogErrorsCheck" Content="Errors (Recommended)" IsChecked="True" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
						</StackPanel>

						<StackPanel Orientation="Horizontal" Margin="0,16,0,0" Spacing="8">
							<Button Content="View Logs" Click="OnViewLogsClick" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
							<Button Content="Clear Logs" Click="OnClearLogsClick" IsEnabled="{Binding #EnableLoggingSwitch.IsChecked}"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Action Buttons -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,20,0,0">
					<Button Classes="secondary" Content="Close" Click="OnCloseClick" MinWidth="100"/>
					<Button Classes="primary" Content="Save" Click="OnSaveClick" MinWidth="100"/>
				</StackPanel>
				</StackPanel>
				
				<!-- Privacy Settings -->
				<StackPanel x:Name="PrivacyPanel" IsVisible="False">
					<local:CookiesPage x:Name="CookiesView"/>
				</StackPanel>

				<!-- Developer Settings -->
				<StackPanel x:Name="DeveloperPanel" IsVisible="False">
					<TextBlock Text="Developer Tools" FontSize="24" FontWeight="Bold" Margin="0,0,0,30" Foreground="{DynamicResource PrimaryTextBrush}"/>

					<!-- DOM Comparison Section -->
					<Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
						<StackPanel>
							<TextBlock Text="DOM Comparison" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
							<TextBlock Text="Compare our parsed DOM tree against the original HTML source to identify parsing discrepancies." 
									   TextWrapping="Wrap" 
									   Margin="0,0,0,16"
									   Foreground="{DynamicResource MutedTextBrush}"/>

							<Button x:Name="BtnCompareDom" Content="Compare Current Page" Click="OnCompareDomClick" Classes="primary"/>
							
							<!-- Stats Display -->
							<Border x:Name="DomStatsPanel" IsVisible="False" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="4" Padding="12" Margin="0,16,0,0">
								<StackPanel>
									<TextBlock Text="DOM Statistics" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
									<TextBlock x:Name="DomStatsText" Text="" Foreground="{DynamicResource MutedTextBrush}"/>
								</StackPanel>
							</Border>

							<!-- Comparison Output -->
							<Grid x:Name="ComparisonGrid" IsVisible="False" Margin="0,16,0,0" ColumnDefinitions="*,*" RowDefinitions="Auto,*">
								<TextBlock Grid.Row="0" Grid.Column="0" Text="Parsed DOM" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
								<TextBlock Grid.Row="0" Grid.Column="1" Text="Raw HTML" FontWeight="SemiBold" Margin="8,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
								
								<ScrollViewer Grid.Row="1" Grid.Column="0" MaxHeight="300" VerticalScrollBarVisibility="Auto">
									<TextBox x:Name="ParsedDomOutput" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="{DynamicResource WindowBackgroundBrush}"/>
								</ScrollViewer>
								<ScrollViewer Grid.Row="1" Grid.Column="1" MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="8,0,0,0">
									<TextBox x:Name="RawHtmlOutput" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" Background="{DynamicResource WindowBackgroundBrush}"/>
								</ScrollViewer>
							</Grid>
						</StackPanel>
					</Border>
				</StackPanel>

			</Panel>
		</ScrollViewer>
		<!-- Notification Popup -->
		<Border x:Name="NotificationPopup" 
				Grid.Column="1" 
				HorizontalAlignment="Right" 
				VerticalAlignment="Bottom" 
				Margin="0,0,30,80" 
				Background="{DynamicResource SurfaceBrush}" 
				BorderBrush="{DynamicResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="6" 
				Padding="16,12" 
				IsVisible="False">
			<StackPanel Orientation="Horizontal" Spacing="10">
				<TextBlock Text="✓" Foreground="#6CCB5F" FontWeight="Bold" FontSize="16"/>
				<TextBlock Text="Settings Saved" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="14"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
